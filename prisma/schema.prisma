generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js (Auth.js) Prisma Adapter models.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]
  memberships Member[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Domain models for household/space/item management.
model Household {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]
  spaces  Space[]
  items   Item[]
  events  ItemEvent[]
  tags    Tag[]
}

model Member {
  id           String      @id @default(cuid())
  householdId  String
  userId       String
  role         MemberRole  @default(MEMBER)
  displayName  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  itemEvents ItemEvent[] @relation("ActorMember")
  ownedItems Item[]      @relation("OwnerMember")

  @@unique([householdId, userId])
  @@index([userId])
  @@index([householdId])
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Space {
  id          String   @id @default(cuid())
  householdId String
  parentId    String?
  name        String
  type        String?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent    Space?    @relation("SpaceTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Space[]   @relation("SpaceTree")

  items Item[]

  @@index([householdId, parentId])
  @@index([householdId, name])
}

model Item {
  id             String     @id @default(cuid())
  householdId    String
  spaceId        String
  name           String
  imageDataUrl   String?
  category       String?
  quantity       Decimal    @default(1)
  unit           String?
  status         ItemStatus @default(IN_USE)
  ownerMemberId  String?
  note           String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  space     Space     @relation(fields: [spaceId], references: [id], onDelete: Restrict)
  owner     Member?   @relation("OwnerMember", fields: [ownerMemberId], references: [id], onDelete: SetNull)

  tags   ItemTag[]
  events ItemEvent[]

  @@index([householdId, spaceId])
  @@index([householdId, name])
}

enum ItemStatus {
  IN_USE
  IDLE
  CONSUMABLE
  LENT
  DISPOSED
}

model Tag {
  id          String   @id @default(cuid())
  householdId String
  name        String
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  items     ItemTag[]

  @@unique([householdId, name])
  @@index([householdId])
}

model ItemTag {
  itemId String
  tagId  String

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@index([tagId])
}

model ItemEvent {
  id            String        @id @default(cuid())
  householdId   String
  itemId        String
  actorMemberId String?
  type          ItemEventType
  fromSpaceId   String?
  toSpaceId     String?
  payloadJson   Json?
  createdAt     DateTime      @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  actor     Member?   @relation("ActorMember", fields: [actorMemberId], references: [id], onDelete: SetNull)

  @@index([householdId, itemId, createdAt(sort: Desc)])
  @@index([householdId, createdAt(sort: Desc)])
}

enum ItemEventType {
  CREATE
  UPDATE
  MOVE
  CHECK
  DISPOSE
}
